{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/broadcast/:path*",
      "destination": "/api/broadcast/index"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/tree",
      "destination": "/morning-energy-tree/index.html"
    },
    {
      "source": "/roll-call",
      "destination": "/magic-roll-call/index.html"
    },
    {
      "source": "/homework",
      "destination": "/homework-crush/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}