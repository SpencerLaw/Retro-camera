{
  "name": "broadcast-receiver",
  "version": "1.0.0",
  "description": "班级广播接收端 - 桌面版",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "build": "electron-builder"
  },
  "author": "Anypok",
  "license": "ISC",
  "dependencies": {
    "electron-is-dev": "^2.0.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "baby.lovedare.broadcast",
    "productName": "ClassBroadcastReceiver",
    "artifactName": "ClassBroadcastReceiver_Setup.${ext}",
    "copyright": "Copyright © 2024",
    "mac": {
      "category": "public.app-category.education"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "ClassBroadcastReceiver",
      "runAfterFinish": true
    }
  }
}
